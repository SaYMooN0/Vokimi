@model Vokimi.Models.ViewModels.RegistrationViewModel

<h1>registration page</h1>



<form asp-action="Registration" asp-controller="Account" method="post">
    <div class="form-group">
        <label asp-for="Nickname">Nickname</label>
        <input asp-for="Nickname" class="form-control" required />
    </div>
    <div class="form-group">
        <label asp-for="BirthDate">Birth date</label>
        <input asp-for="BirthDate" class="form-control" required />
    </div>
    <div class="form-group">
        <label asp-for="Email">Email</label>
        <input asp-for="Email" class="form-control" required />
    </div>

    <div class="form-group">
        <label asp-for="Password">Password</label>
        <input asp-for="Password" class="form-control" required />
    </div>

    <div class="form-group">
        <label asp-for="ConfirmPassword">Repeat password</label>
        <input asp-for="ConfirmPassword" class="form-control" required />
    </div>
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <p class="text-danger">@Model.ErrorMessage</p>
    }
    <button type="submit" class="btn btn-primary">Register</button>
</form>
<p>Already have an account?</p>
<a asp-action="Authorization">Go to the authorization page</a>
@{
}
